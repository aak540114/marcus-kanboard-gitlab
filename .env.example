HANGMAN_MAX_ATTEMPTS=6
HANGMAN_WORD_LIST=./words.txt

# --- Marcus + Kanboard + Gitea stack (docker-compose.yml) -----------------
#
# Copy this file to .env and fill these in, or just run ./scripts/setup.sh
# which generates/prompts for all of them automatically.

# Kanboard app-level JSON-RPC API token. Set as API_AUTHENTICATION_TOKEN on
# the kanboard container too — Marcus and Kanboard must agree on this value.
# Generate one yourself with: openssl rand -hex 32
KANBOARD_API_TOKEN=

# Numeric Kanboard project id Marcus operates against. Left blank here —
# scripts/setup.sh resolves and writes this automatically after creating
# (or finding) the project named KANBOARD_PROJECT_NAME.
KANBOARD_PROJECT_ID=

# Project name scripts/setup.sh creates in Kanboard if it doesn't exist.
KANBOARD_PROJECT_NAME=Marcus Project

# Shared secret Kanboard appends as ?token=... on outbound webhook calls;
# Marcus's webhook receiver (src/core/kanboard_webhook_receiver.py) checks
# it matches. Generate with: openssl rand -hex 32
KANBOARD_WEBHOOK_TOKEN=

# Gitea admin account password (username: root). scripts/setup.sh
# generates a random one if this is left blank — set your own here if
# you'd rather choose it.
GITEA_ADMIN_PASSWORD=

# Gitea Personal Access Token (scopes: write:repository, read:user).
# scripts/setup.sh generates and writes this automatically.
GITEA_TOKEN=

# Shared secret Gitea signs push-webhook deliveries with (HMAC-SHA256, sent
# as the X-Gitea-Signature header); Marcus's receiver
# (src/core/gitea_webhook_receiver.py) checks it matches before triggering
# a dev-environment refresh. scripts/setup.sh generates this automatically
# — no manual step in Gitea's UI is needed either: GiteaManager.create_webhook()
# registers the webhook for you the first time each project's repo is
# provisioned. Generate your own with: openssl rand -hex 32
GITEA_WEBHOOK_TOKEN=

# URL Gitea POSTs push events to. Defaults to the Docker service name
# (machine-to-machine call, not browser-facing like MARCUS_URL above) —
# only set this if Marcus isn't reachable at http://marcus:4298 from the
# Gitea container, e.g. a split multi-host deployment.
GITEA_WEBHOOK_TARGET_URL=

# Where Marcus itself runs: "docker" (default, part of this compose stack)
# or "native" (Kanboard/Gitea stay in Docker, but Marcus runs directly on
# this host — see scripts/run_marcus_native.sh and README's "Hybrid mode:
# Marcus outside Docker" section). scripts/setup.sh asks this once, up
# front. The main reason to choose "native": on macOS, Claude Code's login
# session lives in the Keychain, which a Linux container can't reach — so
# MARCUS_AI_PROVIDER=claude_subscription silently fails in Docker on a Mac
# but works fine when Marcus runs natively (a real macOS process CAN read
# the Keychain, the same way your interactive `claude login` session does).
MARCUS_RUN_MODE=docker

# AI provider for Marcus's OWN decomposition/dependency-inference/effort-
# estimation calls (not the coding agents you connect via MCP — those
# already use their own auth independently of this setting).
#
# scripts/setup.sh sets this automatically, no prompt: if CLAUDE_API_KEY
# is already set below, it uses "anthropic"; otherwise, if this machine
# has an authenticated `claude` CLI login (`claude login`), it uses
# "claude_subscription" — Marcus's own AI calls then ride your Claude
# Pro/Max subscription via a non-interactive `claude` CLI call inside the
# marcus container (see docker-compose.yml's ~/.claude.json /
# ~/.claude/.credentials.json bind mounts), no API key needed.
# Leave blank to let scripts/setup.sh choose; set explicitly to override.
MARCUS_AI_PROVIDER=

# Model alias passed to `claude --model` (e.g. sonnet, opus, haiku).
# Only used when MARCUS_AI_PROVIDER=claude_subscription.
MARCUS_CLAUDE_CLI_MODEL=sonnet

# Only required if MARCUS_AI_PROVIDER=anthropic (or left blank with no
# local `claude` CLI login available for scripts/setup.sh to use instead).
# Get one at https://console.anthropic.com/
CLAUDE_API_KEY=

# Host port Marcus's MCP endpoint is published on. Only needed if 4298
# is already taken on your machine.
MARCUS_PORT=4298

# Which host interface each service's port is published on — controls
# whether other machines can reach it at all (separate from any firewall
# you also have). scripts/setup.sh asks ONE question ("allow remote
# access?") and sets all three of MARCUS_BIND_HOST / GITEA_BIND_HOST /
# KANBOARD_BIND_HOST together (default "no" / localhost-only if there's no
# terminal to ask). They're separate variables — not one shared value —
# because AI agents only ever need Marcus's port (MCP) and Gitea's port
# (git clone/push) open; Kanboard's port only matters for a HUMAN browsing
# its UI, and only when opting into "allow remote access" does setup.sh
# also replace Kanboard's admin/admin login (see KANBOARD_ADMIN_USERNAME
# below) before ever publishing that port.
#   127.0.0.1  (default) - localhost only, unreachable from other machines
#   0.0.0.0             - reachable from other machines (e.g. a remote
#                          VPS deployment with AI agents connecting in),
#                          once your firewall/network allows it
MARCUS_BIND_HOST=127.0.0.1
GITEA_BIND_HOST=127.0.0.1
KANBOARD_BIND_HOST=127.0.0.1

# Kanboard admin login. scripts/setup.sh generates these (a fixed username,
# a random password) and creates this account via Kanboard's JSON-RPC API,
# then DISABLES the built-in "admin"/"admin" account — done only when
# KANBOARD_BIND_HOST=0.0.0.0, since Kanboard's API has no way to rotate an
# existing user's password, so the fixed admin/admin default can't safely
# be exposed as-is. Left blank / unused for the localhost-only default.
KANBOARD_ADMIN_USERNAME=
KANBOARD_ADMIN_PASSWORD=

# Public-facing base URL for Marcus, embedded into Kanboard's own pages so
# a HUMAN's browser can fetch Marcus (Active Agents badge, Gate toggle,
# Project Description link). Must be an address that browser can resolve —
# NOT "localhost" (defaults to that, which only works when Kanboard's UI is
# also being viewed from this machine). scripts/setup.sh sets this
# automatically to https://<domain> when you choose the HTTPS option; for
# plain-HTTP remote access it's left for you to set to this host's real
# address if you want those widgets to work for a remote human too — the
# rest of the stack (agents, git) works either way.
MARCUS_URL=

# Shared bearer token connecting AI agents must present to Marcus as
# `Authorization: Bearer <token>`. When set, Marcus rejects any request
# without it (401), so unaccounted agents can't read or change tickets,
# branches, or code. Leave BLANK for the localhost-only default (auth off);
# scripts/setup.sh generates one automatically when you opt into remote
# access. Generate your own with: openssl rand -hex 32
# Agents connect with:
#   claude mcp add --transport http marcus http://<host>:4298/mcp \
#     -H "Authorization: Bearer <token>"
MARCUS_AGENT_TOKEN=

# Browser-facing base URL of Gitea — the address a HUMAN's browser and a
# REMOTE agent use to reach Gitea (NOT the internal `GITEA_URL`, which is
# `http://gitea:3000` inside Docker and unreachable from outside). Marcus uses
# this to build the clone URL and the Kanboard repo/branch links it hands out.
# Defaults to http://localhost:3000; set to your https://<domain> for remote
# access.
GITEA_PUBLIC_URL=http://localhost:3000

# Whether get_work_context embeds git credentials in the clone_url it returns,
# so an agent can `git clone` a PRIVATE repo with zero extra setup. Default
# "true" (seamless). Set "false" to hand out a credential-less URL and
# configure git auth on the agent host yourself.
MARCUS_EMBED_GIT_CREDENTIALS=true

# OPTIONAL, RECOMMENDED for embedded credentials: a dedicated, repo-scoped
# Gitea token (and its owning username) handed to agents instead of the admin
# GITEA_TOKEN. Because the token lands on every agent host AND inside the LLM's
# context, a scoped token contains the blast radius of a leak to just the
# project repos. Create a limited Gitea user (e.g. "marcus-agent"), generate a
# token for it, and set both here. If unset, Marcus falls back to GITEA_TOKEN.
GITEA_AGENT_USERNAME=
GITEA_AGENT_TOKEN=

# How many tickets Marcus will keep "in progress" at the same time — i.e.
# how many AI coding agents can work in parallel. Each in-progress ticket
# is handed to a distinct agent "slot"; when every slot is busy, further
# assigned tickets simply wait in the Ready column until a slot frees. A
# busy slot is NEVER interrupted mid-work (its branch and saved ticket
# context are preserved), so raising or lowering this only affects how many
# NEW tickets start, never work already underway. Defaults to 3. Set to 1
# for strict one-ticket-at-a-time behavior.
MARCUS_MAX_PARALLEL_AGENTS=3
